{
  "expo": {
    "name": "AssetFlow",
    "slug": "assetflow-ios",
    "version": "1.0.0",
    "platforms": [
      "ios"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F7F3EA",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.assetflow.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "AssetFlow uses Face ID to unlock your local finance data."
      }
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow AssetFlow to use Face ID to unlock your local finance data."
        }
      ]
    ]
  }
}
