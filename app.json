{
  "expo": {
    "name": "AssetFlow",
    "slug": "assetflow-ios",
    "version": "1.0.0",
    "platforms": [
      "ios"
    ],
    "icon": "./icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F7F3EA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "icon": "./icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.assetflow.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "3bf40ea9-0ada-4093-ac79-7bdebe0158be"
      }
    },
    "owner": "kazuotm",
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
